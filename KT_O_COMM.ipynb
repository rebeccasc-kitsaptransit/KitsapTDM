   },
   "outputs": [],
   "source": [
    "def get_day_category(day_type_str):\n",
    "    s = str(day_type_str).lower()\n",
    "    if 'weekday' in s or 'm-th' in s:\n",
    "        return 'weekday'\n",
    "    elif 'friday' in s:\n",
    "        return 'friday'\n",
    "    elif 'saturday' in s:\n",
    "        return 'saturday'\n",
    "    elif 'sunday' in s:\n",
    "        return 'sunday'\n",
    "    return 'all'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "89ab6d64",
   "metadata": {
    "lines_to_next_cell": 1
   },
   "outputs": [],
   "source": [
    "def classify_transit_coverage(day_part, day_category):\n",
    "    \"\"\"\n",
    "    Classify whether a time period falls within transit service hours.\n",
    "    Returns 'Within Service Hours', 'Outside Service Hours', or 'Partial'.\n",
    "    Based on StreetLight aggregated periods — not individual hour resolution.\n",
    "    \"\"\"\n",
    "    if day_category not in TRANSIT_HOURS or day_part not in PERIOD_HOUR_MAP:\n",
    "        return 'Unknown'\n",
    "\n",
    "    period_start, period_end = PERIOD_HOUR_MAP[day_part]\n",
    "    svc_start = TRANSIT_HOURS[day_category]['start']\n",
    "    svc_end   = TRANSIT_HOURS[day_category]['end']\n",
    "\n",
    "    if period_start >= svc_end or period_end <= svc_start:\n",
    "        return 'Outside Service Hours'\n",
    "    elif period_start >= svc_start and period_end <= svc_end:\n",
    "        return 'Within Service Hours'\n",
    "    else:\n",
    "        return 'Partial Overlap'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c750450b",
   "metadata": {
    "lines_to_next_cell": 1
   },
   "outputs": [],
   "source": [
    "def categorize_trip_length(length):\n",
    "    if pd.isna(length):\n",
    "        return 'Unknown'\n",
    "    for label, (lo, hi) in TRIP_LENGTH_BINS.items():\n",
    "        if lo <= length < hi:\n",
    "            return label\n",
    "    return 'Unknown'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "82ce66cb",
   "metadata": {
    "lines_to_next_cell": 1
   },
   "outputs": [],
   "source": [
    "def categorize_speed(speed):\n",
    "    if pd.isna(speed):\n",
    "        return 'Unknown'\n",
    "    for label, (lo, hi) in SPEED_BINS.items():\n",
    "        if lo <= speed < hi:\n",
    "            return label\n",
    "    return 'Unknown'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8b28e6f6",
   "metadata": {
    "lines_to_next_cell": 1
   },
   "outputs": [],
   "source": [
    "def weighted_avg(values, weights):\n",
    "    mask = ~(pd.isna(values) | pd.isna(weights)) & (weights > 0)\n",
    "    if mask.sum() == 0:\n",
    "        return np.nan\n",
    "    return np.average(values[mask], weights=weights[mask])"
   ]
  },
