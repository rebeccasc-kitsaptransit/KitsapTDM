   "source": [
    "for corridor in present_corridors:\n",
    "    cdata = df[df['Destination Zone Name'] == corridor]\n",
    "    if cdata.empty:\n",
    "        continue\n",
    "\n",
    "    total_vol = cdata[VOLUME_COL].sum()\n",
    "    avg_len   = weighted_avg(cdata[TRIP_LENGTH_COL], cdata[VOLUME_COL])\n",
    "    avg_spd   = weighted_avg(cdata[TRIP_SPEED_COL],  cdata[VOLUME_COL])\n",
    "\n",
    "    local_vol = cdata[cdata['Trip_Length_Cat'].isin(\n",
    "        ['Very Short (0–2 mi)', 'Short (2–4 mi)'])][VOLUME_COL].sum()\n",
    "    pass_vol  = cdata[cdata['Trip_Length_Cat'].isin(\n",
    "        ['Long (7–15 mi)', 'Regional (15+ mi)'])][VOLUME_COL].sum()\n",
    "\n",
    "    pct_local = (local_vol / total_vol * 100) if total_vol > 0 else 0\n",
    "    pct_pass  = (pass_vol  / total_vol * 100) if total_vol > 0 else 0\n",
    "\n",
    "    outside_vol = cdata[cdata['Transit_Coverage'] == 'Outside Service Hours'][VOLUME_COL].sum()\n",
    "    pct_outside = (outside_vol / total_vol * 100) if total_vol > 0 else 0\n",
    "\n",
    "    # Typology — based on trip length distribution only\n",
    "    if pct_local >= 55:\n",
    "        typology = 'Local Connector'\n",
    "        typology_note = 'Majority of trips are short — consistent with commercial node access'\n",
    "    elif pct_pass >= 55:\n",
    "        typology = 'Pass-Through Arterial'\n",
    "        typology_note = 'Majority of trips are long — corridor primarily serves through-travel'\n",
    "    else:\n",
    "        typology = 'Mixed'\n",
    "        typology_note = 'Neither local nor pass-through trips dominate'\n",
    "\n",
    "    typology_rows.append({\n",
    "        'Corridor':            corridor,\n",
    "        'Description':         CORRIDOR_DESCRIPTIONS.get(corridor, ''),\n",
    "        'Total_Volume':        round(total_vol),\n",
    "        'Avg_Trip_Length_mi':  round(avg_len, 2) if not np.isnan(avg_len) else 'N/A',\n",
    "        'Avg_Speed_mph':       round(avg_spd, 1) if not np.isnan(avg_spd) else 'N/A',\n",
    "        'Pct_Local_Trips':     round(pct_local, 1),\n",
    "        'Pct_PassThru_Trips':  round(pct_pass, 1),\n",
    "        'Pct_Outside_Svc_Hrs': round(pct_outside, 1),\n",
    "        'Typology':            typology,\n",
    "        'Typology_Note':       typology_note\n",
    "    })"
   ]
