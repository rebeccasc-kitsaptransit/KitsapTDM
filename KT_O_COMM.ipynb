   "source": [
    "print(\"=\" * 70)\n",
    "print(\"ANALYSIS 1: VOLUME HEATMAPS BY CORRIDOR\")\n",
    "print(\"=\" * 70)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3525d560",
   "metadata": {},
   "outputs": [],
   "source": [
    "PERIOD_ORDER = [k for k in TIME_PERIOD_LABELS if k != '0: All Day (12am-12am)']\n",
    "PERIOD_LABELS_SHORT = {\n",
    "    '1: Early AM (12am-6am)': 'Early AM\\n(12a–6a)',\n",
    "    '2: Peak AM (6am-10am)':  'Peak AM\\n(6a–10a)',\n",
    "    '3: Mid-Day (10am-3pm)':  'Mid-Day\\n(10a–3p)',\n",
    "    '4: Peak PM (3pm-7pm)':   'Peak PM\\n(3p–7p)',\n",
    "    '5: Late PM (7pm-12am)':  'Late PM\\n(7p–12a)'\n",
    "}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "39836ca2",
   "metadata": {},
   "outputs": [],
   "source": [
    "DAY_LABELS_SHORT = {\n",
    "    '0: All Days (M-Su)':  'All Days',\n",
    "    '1: Weekday (M-Th)':   'Mon–Thu',\n",
    "    '2: Friday (F-F)':     'Friday',\n",
    "    '3: Saturday (Sa-Sa)': 'Saturday',\n",
    "    '4: Sunday (Su-Su)':   'Sunday'\n",
    "}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "01630d85",
   "metadata": {},
   "outputs": [],
   "source": [
    "for corridor in present_corridors:\n",
    "    cdata = df_hourly[df_hourly['Destination Zone Name'] == corridor]\n",
    "    if cdata.empty:\n",
    "        print(f\"  {corridor}: no hourly data — skipped\")\n",
    "        continue\n",
    "\n",
    "    pivot = cdata.pivot_table(\n",
    "        values=VOLUME_COL,\n",
    "        index='Day Part',\n",
    "        columns='Day Type',\n",
    "        aggfunc='sum',\n",
    "        fill_value=0\n",
    "    )\n",
    "    pivot = pivot.reindex(\n",
    "        [p for p in PERIOD_ORDER if p in pivot.index]\n",
    "    )\n",
    "    pivot = pivot[[c for c in DAY_TYPE_ORDER if c in pivot.columns]]\n",
    "    pivot.index   = [PERIOD_LABELS_SHORT.get(i, i) for i in pivot.index]\n",
    "    pivot.columns = [DAY_LABELS_SHORT.get(c, c) for c in pivot.columns]\n",
    "\n",
    "    max_val = pivot.values.max()\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(11, 6))\n",
    "    sns.heatmap(\n",
    "        pivot, annot=True, fmt='.0f',\n",
    "        cmap='YlOrRd', linewidths=0.5,\n",
    "        vmin=0, vmax=max_val,\n",
    "        cbar_kws={'label': 'Avg Daily Vehicle Trips', 'format': comma_fmt},\n",
    "        ax=ax\n",
    "    )\n",
    "\n",
    "    # Transit service hour overlays — draw rectangle per day column\n",
    "    day_cols = list(pivot.columns)\n",
    "    period_rows = list(pivot.index)\n",
    "\n",
    "    day_cat_map = {\n",
    "        'All Days': 'weekday', 'Mon–Thu': 'weekday', 'Friday': 'friday',\n",
    "        'Saturday': 'saturday', 'Sunday': 'sunday'\n",
    "    }\n",
    "    period_original = [p for p in PERIOD_ORDER if PERIOD_LABELS_SHORT.get(p, p) in period_rows]\n",
    "\n",
    "    for col_idx, day_label in enumerate(day_cols):\n",
    "        day_cat = day_cat_map.get(day_label, 'weekday')\n",
    "        if day_cat not in TRANSIT_HOURS:\n",
    "            continue\n",
    "        svc_start = TRANSIT_HOURS[day_cat]['start']\n",
    "        svc_end   = TRANSIT_HOURS[day_cat]['end']\n",
    "\n",
    "        covered_rows = []\n",
    "        for row_idx, orig_period in enumerate(period_original):\n",
    "            if orig_period in PERIOD_HOUR_MAP:\n",
    "                ps, pe = PERIOD_HOUR_MAP[orig_period]\n",
    "                if ps >= svc_start and pe <= svc_end:\n",
    "                    covered_rows.append(row_idx)\n",
    "\n",
    "        if covered_rows:\n",
    "            row_start = min(covered_rows)\n",
    "            row_end   = max(covered_rows) + 1\n",
    "            rect = mpatches.FancyBboxPatch(\n",
    "                (col_idx, row_start),\n",
    "                1, row_end - row_start,\n",
    "                boxstyle=\"square,pad=0\",\n",
    "                linewidth=2.5,\n",
    "                edgecolor='#00AA44',\n",
    "                facecolor='none',\n",
    "                linestyle='--',\n",
    "                zorder=5\n",
    "            )\n",
    "            ax.add_patch(rect)\n",
    "\n",
    "    desc = CORRIDOR_DESCRIPTIONS.get(corridor, corridor)\n",
    "    ax.set_title(\n",
    "        f'Hourly Traffic Volume — {corridor}\\n{desc}\\n'\n",
    "        f'(Green dashed outline = current Kitsap Transit service hours)',\n",
    "        fontsize=11, pad=12\n",
    "    )\n",
    "    ax.set_xlabel('Day Type', fontsize=10)\n",
    "    ax.set_ylabel('Time Period', fontsize=10)\n",
    "    plt.tight_layout()\n",
    "\n",
    "    out = os.path.join(OUTPUT_DIR, 'heatmaps', f'Volume_{corridor}.pdf')\n",
    "    plt.savefig(out, dpi=300, bbox_inches='tight')\n",
    "    plt.close()\n",
    "    print(f\"  {corridor}: saved (peak volume {max_val:,.0f})\")"
   ]
